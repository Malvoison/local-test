# Ollama HTTP endpoint.
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model used by the CLI.
OLLAMA_MODEL=gemma4:e4b

# Optional for news prompts. Leave blank if you do not plan to use the news tool.
NEWS_API_KEY=

# Request timeout in seconds for Ollama and provider HTTP requests.
REQUEST_TIMEOUT=30.0

# One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
